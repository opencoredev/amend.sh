{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["WORKTREE_NAME"],
  "globalDependencies": [
    "docs/agent-ready-production-report.schema.json",
    "docs/agent-ready-live-report.schema.json",
    "docs/agent-ready-status-report.schema.json",
    "docs/agent-ready-completion-audit-report.schema.json"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".output/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "format:check": {},
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:setup": {
      "cache": false,
      "persistent": true
    }
  }
}
