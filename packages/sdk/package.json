{
  "name": "@amend/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./embed": {
      "types": "./dist/embed.d.ts",
      "default": "./dist/embed.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "generate:openapi-types": "bun run --cwd ../api-spec generate:types"
  },
  "devDependencies": {
    "@amend/config": "workspace:*",
    "typescript": "catalog:"
  }
}
