CONVEX_DEPLOYMENT=local:local-leodev-amend
CONVEX_URL=http://127.0.0.1:3210
CONVEX_SITE_URL=http://127.0.0.1:3211

# Set with `bunx convex env set ...` for the active Convex deployment.
SITE_URL=http://amend.localhost:1355
BETTER_AUTH_SECRET=replace-with-a-generated-secret
GITHUB_WEBHOOK_SECRET=replace-with-your-github-webhook-secret
GITHUB_APP_ID=replace-with-your-github-app-id
GITHUB_APP_SLUG=replace-with-your-github-app-slug
GITHUB_APP_CLIENT_ID=replace-with-your-github-app-client-id
GITHUB_APP_CLIENT_SECRET=replace-with-your-github-app-client-secret
GITHUB_APP_PRIVATE_KEY=replace-with-your-github-app-private-key
AMEND_API_TOKEN=replace-with-your-api-token
AMEND_AI_PROVIDER=openai
OPENAI_API_KEY=replace-with-your-provider-key
OPENAI_MODEL=gpt-5.1-mini
OPENROUTER_API_KEY=replace-with-your-openrouter-key
OPENROUTER_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
CROF_API_KEY=replace-with-your-crof-key
CROF_MODEL=kimi-k2.6
CROF_BASE_URL=https://crof.ai/v1
RESEND_API_KEY=replace-with-your-email-provider-key
EMAIL_FROM=updates@example.com
STRIPE_SECRET_KEY=replace-with-your-billing-secret
STRIPE_WEBHOOK_SECRET=replace-with-your-stripe-webhook-secret
