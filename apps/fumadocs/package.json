{
  "name": "fumadocs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check-types": "fumadocs-mdx && tsc --noEmit",
    "dev": "portless docs.${WORKTREE_NAME:-amend} vite dev",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "start": "node .output/server/index.mjs",
    "types:check": "bun run check-types",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-start": "^1.168.25",
    "fumadocs-core": "^16.10.2",
    "fumadocs-mdx": "^15.0.12",
    "fumadocs-ui": "^16.10.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "nitro": "^3.0.260522-beta",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
