# ── Gateway (shared by all connectors) ──────────────────────────────────────
# Today this points at the Discord-specific endpoint; it will later move to the
# generic /ingest/signal endpoint once the backend grows one.
AMEND_INGEST_URL=https://<your-deployment>.convex.site/ingest/discordMessage
AMEND_API_TOKEN=
# Comma-separated connector ids to run. Empty = all built-in connectors (discord).
GATEWAY_CONNECTORS=
# Gateway/forwarder verbose logging (default on). Set to 0 to quiet.
GATEWAY_DEBUG=1

# ── Discord connector ────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
# Comma-separated channel IDs to watch (the cost control). Empty = all channels.
DISCORD_LISTEN_CHANNEL_IDS=
# Comma-separated guild IDs to watch. Empty = all guilds the bot is in.
DISCORD_LISTEN_GUILD_IDS=
# Verbose per-message logging (default on, overrides GATEWAY_DEBUG). Set to 0 to quiet.
DISCORD_DEBUG=1
